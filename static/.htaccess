# Enable Rewrite Engine
RewriteEngine On

# Redirect www to non-www (HTTPS)
RewriteCond %{HTTP_HOST} ^www\.visioninit\.dev [NC]
RewriteRule ^(.*)$ https://visioninit.dev/$1 [L,R=301]

# Security and Performance Headers (Requires mod_headers)
<IfModule mod_headers.c>
    # --- Content Security Policy (CSP) - WITH unsafe-inline ---
    # Keeping unsafe-inline due to site constraints (Acknowledged risk)
    # Ensure all listed domains are necessary.
    Header set Content-Security-Policy "\
        default-src 'self'; \
        script-src 'self' https://www.googletagmanager.com https://static.cloudflareinsights.com https://app.cal.com https://cal.com https://*.stripe.com 'unsafe-inline'; \
        style-src 'self' https://fonts.googleapis.com https://cdnjs.cloudflare.com 'unsafe-inline'; \
        img-src 'self' data: https://via.placeholder.com https://*.google-analytics.com https://*.googletagmanager.com; \
        font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; \
        connect-src 'self' https://cloudflareinsights.com https://cal.com https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com; \
        frame-src 'self' https://cal.com https://app.cal.com https://js.stripe.com https://hooks.stripe.com; \
        frame-ancestors 'none'; \
        form-action 'self'; \
        object-src 'none'; \
        base-uri 'self'; \
        upgrade-insecure-requests;"

    # --- HTTP Strict Transport Security (HSTS) ---
    # Ensures browsers only connect via HTTPS. Only enable if your site ALWAYS uses HTTPS.
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

    # --- Cross-Origin-Opener-Policy (COOP) ---
    Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"

    # --- X-Frame-Options (XFO) ---
    # Provides clickjacking protection for older browsers (CSP frame-ancestors is preferred).
    Header set X-Frame-Options "SAMEORIGIN"

    # --- X-Content-Type-Options ---
    # Prevents MIME-type sniffing.
    Header set X-Content-Type-Options "nosniff"

    # --- Referrer-Policy ---
    # Controls how much referrer information is sent.
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # --- Permissions-Policy (Restrictive Default) ---
    # Defines features available to the site.
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), fullscreen=(self)"
</IfModule>

# Cache Control Headers (Requires mod_expires)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month" # Default for other content

  # HTML
  ExpiresByType text/html                 "access plus 0 seconds" # Or "access plus 1 day" if appropriate

  # Data
  ExpiresByType application/atom+xml      "access plus 1 hour"
  ExpiresByType application/rdf+xml       "access plus 1 hour"
  ExpiresByType application/rss+xml       "access plus 1 hour"
  ExpiresByType application/json          "access plus 0 seconds" # Often dynamic
  ExpiresByType application/ld+json       "access plus 0 seconds" # Often dynamic
  ExpiresByType application/schema+json   "access plus 0 seconds" # Often dynamic
  ExpiresByType application/xml           "access plus 0 seconds" # Text/xml below is more specific
  ExpiresByType text/xml                  "access plus 0 seconds"

  # Favicon and site icons
  ExpiresByType image/vnd.microsoft.icon  "access plus 1 week"
  ExpiresByType image/x-icon              "access plus 1 week"
  ExpiresByType image/png                 "access plus 1 week"
  ExpiresByType image/jpg                 "access plus 1 week"
  ExpiresByType image/jpeg                "access plus 1 week"
  ExpiresByType image/gif                 "access plus 1 week"
  ExpiresByType image/webp                "access plus 30 days"
  ExpiresByType image/svg+xml             "access plus 30 days"

  # Web fonts
  # Embedded OpenType (EOT)
  ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
  # TrueType (TTF)
  ExpiresByType application/x-font-ttf    "access plus 1 year"
  # Web Open Font Format (WOFF)
  ExpiresByType application/font-woff     "access plus 1 year"
  ExpiresByType application/x-font-woff   "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  # Web Open Font Format 2 (WOFF2)
  ExpiresByType application/font-woff2    "access plus 1 year"
  ExpiresByType application/x-font-woff2  "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"

  # CSS and JavaScript
  ExpiresByType text/css                  "access plus 1 year" # For fingerprinted CSS
  ExpiresByType application/javascript    "access plus 1 year" # For fingerprinted JS
  ExpiresByType application/x-javascript  "access plus 1 year" # For fingerprinted JS

  # Other
  ExpiresByType video/mp4                 "access plus 1 month"
  ExpiresByType audio/mpeg                "access plus 1 month"
</IfModule>

# For fingerprinted assets, ensure long cache even if specific type above is shorter
# This uses mod_headers, which is already enabled.
<FilesMatch "\.[a-f0-9]{8,}\.(css|js|woff|woff2|ttf|eot|svg|png|jpg|jpeg|gif|webp)$">
  <IfModule mod_headers.c>
    Header unset Expires
    Header set Cache-Control "public, max-age=31536000, immutable"
  </IfModule>
</FilesMatch>

# Enable Gzip Compression (Requires mod_deflate)
<IfModule mod_deflate.c>
    # Compress common text-based file types
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE image/svg+xml # SVGs are text-based and compress well

    # -- RECOMMENDED TO REMOVE THE FOLLOWING LINES --
    # JPG, PNG, GIF are already compressed. Gzipping them rarely helps
    # and can sometimes slightly increase size + adds server overhead.
    # AddOutputFilterByType DEFLATE image/jpg
    # AddOutputFilterByType DEFLATE image/png
    # AddOutputFilterByType DEFLATE image/gif
    # AddOutputFilterByType DEFLATE image/jpeg
</IfModule>
