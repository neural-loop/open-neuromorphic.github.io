{
  "name": "visioninit-website",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "hugo server --buildFuture --disableFastRender --navigateToChanged --verbose",
    "dev:verbose": "hugo server --disableFastRender --navigateToChanged --templateMetrics --templateMetricsHints --buildDrafts --buildExpired --buildFuture --watch --forceSyncStatic -e production --minify",
    "build": "npm run clean && npm run generate-favicons && npm run og-images && hugo --gc --minify --templateMetrics --templateMetricsHints --buildExpired --buildFuture --forceSyncStatic",
    "clean": "rm -rf public/ resources/ tmp/ static/favicon* static/apple-touch-icon.png static/logo.png static/og.jpg static/og.png content/**/og.jpg content/**/og.png content/**/temp-og.html temp-homepage-og.html",
    "lint:scss": "stylelint \"assets/scss/**/*.scss\"",
    "lint:scss:fix": "stylelint \"assets/scss/**/*.scss\" --fix",
    "project-setup": "node ./scripts/projectSetup.js",
    "theme-setup": "node ./scripts/themeSetup.js",
    "og-images": "node scripts/collectOgData.js && node scripts/generateImagesFromData.js",
    "generate-favicons": "node scripts/generateFavicons.js",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "bootstrap": "^5.3.6",
    "mime-types": "^3.0.1",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.5.3",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-toml": "^2.0.4",
    "stylelint": "^16.19.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "toml": "^3.0.0"
  }
}
