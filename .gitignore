# Hugo build output
public/
resources/_gen/
assets/js/bundle.js*
assets/css/main.css*
assets/css/critical/

# Generated OG images within content
content/**/og.jpg
content/**/temp-og.html

# Generated favicons and logo in static
# These ARE generated by scripts, but we WANT them committed to the repo
# so they are available during deployment without needing ImageMagick there.
# DO NOT ignore these:
# static/favicon*.png
# static/favicon.ico
# static/apple-touch-icon.png
# static/logo.png
# static/logo@*.png
# static/og.jpg

# Node modules
node_modules/

# Temporary files
*.tmp
temp-og.html
content/**/temp-og.html
temp-homepage-og.html

# OS generated files
.DS_Store
Thumbs.db

# Temp build artifacts (adjust paths if needed)
/tmp/

# Other ignores
/layouts/sitemap.xml
/.hugo_build.lock
/hugo_stats.json
/output.txt
/output_*.txt # Ignore both full and diff outputs
/.idea/
/.vscode/
/static/apple-touch-icon.png
/static/favicon.ico
/static/favicon.png
/static/favicon-16x16.png
/static/favicon-32x32.png
/static/logo.png
/static/og.jpg
